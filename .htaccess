Options -Indexes
ErrorDocument 404 /404.html

# ── BLOCK SENSITIVE FILES & DIRECTORIES ──────────────────────
RedirectMatch 403 ^/_backup
RedirectMatch 403 ^/serve\.py$
RedirectMatch 403 ^/\.claude
RedirectMatch 403 ^/CLAUDE\.md$
RedirectMatch 403 ^/index-7\.html$
RedirectMatch 403 ^/vastu-riyaz\.html$
RedirectMatch 403 ^/vasturiyaznadaf\.html$

# ── SECURITY HEADERS ─────────────────────────────────────────
<IfModule mod_headers.c>
  Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Permissions-Policy "camera=(), microphone=(), geolocation=()"
  Header always set X-XSS-Protection "1; mode=block"
</IfModule>

RewriteEngine On

# Force HTTPS
RewriteCond %{HTTPS} !=on
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]

# index.html → /
RewriteCond %{THE_REQUEST} \s/+index\.html[\s?] [NC]
RewriteRule ^ / [R=301,L]

# de/index.html → /de/
RewriteCond %{THE_REQUEST} \s/+de/index\.html[\s?] [NC]
RewriteRule ^ /de/ [R=301,L]

# other-page.html → /other-page (including /de/page.html → /de/page)
RewriteCond %{THE_REQUEST} \s/+(.+?)\.html[\s?] [NC]
RewriteRule ^ /%1 [R=301,L]

# Serve clean URLs by appending .html internally (works for /de/about → /de/about.html)
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME} !-f
RewriteRule ^([^\.]+)$ $1.html [NC,L]
